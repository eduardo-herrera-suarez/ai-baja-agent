# =============================================================================
# AI Baja Agent — Environment Variables
# =============================================================================


# -----------------------------------------------------------------------------
# LLM Providers
# At least one API key is required. Active provider is set by LLM_PROVIDER.
# -----------------------------------------------------------------------------

# Groq (fast inference) — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Active model for Groq
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini (fallback) — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# Active provider: "groq" | "google"
LLM_PROVIDER=groq


# -----------------------------------------------------------------------------
# Tavily Web Search
# Used by travel and food nodes for live data enrichment.
# https://app.tavily.com
# -----------------------------------------------------------------------------

TAVILY_API_KEY=your_tavily_api_key


# -----------------------------------------------------------------------------
# ORS — OpenRouteService (Map Routing)
# Used by map_enrichment_node and map_tool for real driving routes.
# https://openrouteservice.org/dev/#/signup
# -----------------------------------------------------------------------------

ORS_API_KEY=your_ors_api_key


# -----------------------------------------------------------------------------
# Langfuse — LLM Observability
# Traces every node call, token count, and agent loop iteration.
# https://us.cloud.langfuse.com
# -----------------------------------------------------------------------------

LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
